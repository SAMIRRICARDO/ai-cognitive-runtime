{
  "name": "ai-lab",
  "version": "0.1.0",
  "description": "Professional AI agents workspace",
  "type": "module",
  "scripts": {
    "start:webhook": "tsx workers/webhookServer.ts",
    "agent": "tsx scripts/run-agent.ts",
    "eval": "tsx scripts/run-eval.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "infra:logs": "docker compose logs -f",
    "costs": "tsx scripts/cost-report.ts",
    "vault:index": "tsx scripts/index-vault.ts",
    "vault:reindex": "tsx scripts/index-vault.ts --force",
    "vault:stats": "tsx scripts/index-vault.ts --stats",
    "memory": "tsx scripts/memory.ts",
    "memory:maintain": "tsx scripts/memory.ts maintain",
    "task": "tsx scripts/run-task.ts",
    "task:dry": "tsx scripts/run-task.ts --dry-run",
    "validate:futurecom": "tsx workers/lead-validation-worker.ts",
    "validate:ctos": "tsx scripts/validate_ctos.ts",
    "enrich:ctos-extra": "tsx scripts/enrich_validate_ctos_extra.ts",
    "validate:ctos-top10": "tsx scripts/validate_ctos_top10.ts",
    "enrich:imprensa-emails": "tsx scripts/enrich_validate_imprensa_emails.ts",
    "dashboard": "node dashboard/server.js",
    "backup": "tsx scripts/backup-runtime.ts",
    "backup:weekly": "tsx scripts/backup-runtime.ts --type weekly",
    "backup:snapshot": "tsx scripts/backup-runtime.ts --type snapshot",
    "restore": "tsx scripts/restore-runtime.ts",
    "restore:list": "tsx scripts/restore-runtime.ts --list",
    "export-memories": "tsx scripts/export-memories.ts",
    "import-memories": "tsx scripts/import-memories.ts",
    "health": "tsx scripts/system-health.ts",
    "leads:acquire": "tsx scheduler/lead-acquisition-scheduler.ts",
    "leads:acquire:daemon": "tsx scheduler/lead-acquisition-scheduler.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@langchain/anthropic": "^0.3.0",
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "langchain": "^0.3.0",
    "openai": "^6.38.0",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.0",
    "pg": "^8.13.0",
    "pgvector": "^0.2.0",
    "playwright": "^1.60.0",
    "puppeteer-core": "^25.0.4",
    "redis": "^4.7.0",
    "resend": "^6.4.2",
    "tsx": "^4.19.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0"
  }
}

# ══════════════════════════════════════════════════════════════════
# AI Cognitive Runtime — Environment Template
# ══════════════════════════════════════════════════════════════════
#
# INSTRUÇÕES:
#   1. cp .env.backup.template .env
#   2. Preencher TODOS os valores marcados com REPLACE_ME
#   3. NUNCA commitar o .env — ele está no .gitignore
#   4. Manter este template atualizado a cada nova variável adicionada
#
# CHECKLIST DE SECRETS:
#   Ver: assets/templates/secure-secrets-checklist.md
#
# ══════════════════════════════════════════════════════════════════

# ── API Keys — CRÍTICO ────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Obtenha em: https://platform.openai.com (para embeddings/memória)
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Obtenha em: https://app.tavily.com (para web search)
# Opcional — sem isso, web_search não funciona
TAVILY_API_KEY=tvly-REPLACE_ME

# ── Email (Resend) — CRÍTICO para outreach ────────────────────────
# Obtenha em: https://resend.com
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=samir.ricardo@vrashows.com.br
RESEND_FROM_NAME=Samir Ricardo | VRASHOWS

# ── Modelos ───────────────────────────────────────────────────────
# Padrão de produção:
DEFAULT_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5-20251001
POWERFUL_MODEL=claude-sonnet-4-6
# Para desenvolvimento com custo baixo, trocar para:
# DEFAULT_MODEL=claude-haiku-4-5-20251001

# ── Infraestrutura Docker ─────────────────────────────────────────
# Padrão conforme docker-compose.yml — alterar apenas se necessário
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://ailab:ailab@localhost:5433/ai_lab

# ── Memória ───────────────────────────────────────────────────────
# "false" = Lean Mode (sem Postgres, sem Redis — zero crash)
# "true"  = Full Mode (requer Docker + DATABASE_URL + OPENAI_API_KEY)
ENABLE_MEMORY=false
MEMORY_PROVIDER=local

# ── Assets ───────────────────────────────────────────────────────
# Caminho do PDF media kit (relativo à raiz do projeto)
# O arquivo NÃO está no git — copiar manualmente
MEDIA_KIT_PDF=./assets/pdfs/vrashows_media_kit_optimized.pdf

# ── Observabilidade ───────────────────────────────────────────────
LOG_LEVEL=info
# Níveis: debug | info | warn | error

# ── Cost / Dev mode ───────────────────────────────────────────────
# DEV_MODE=true → Haiku como padrão, 2048 tokens max, 5 iterações max
DEV_MODE=false
CHEAP_MODE=false
# Descomentar para limitar em produção:
# MAX_TOOL_ITERATIONS=10
# MAX_OUTPUT_TOKENS=8192

# ── Vault (Obsidian) ──────────────────────────────────────────────
VAULT_PATH=~/obsidian-vault

{
  "name": "@vraxia/work",
  "version": "0.1.0",
  "description": "VRAXIA WORK — LinkedIn job hunt & recruit automation module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "hunt": "tsx src/cli/hunt.ts",
    "session:renew": "tsx src/cli/renew-session.ts",
    "catho:login": "tsx src/cli/catho-login.ts",
    "serve": "tsx src/api/server.ts",
    "dashboard": "tsx src/api/server.ts",
    "tunnel": "tsx src/tunnel/start-tunnel.ts",
    "start:full": "concurrently \"npm run serve\" \"npm run tunnel\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "errors:reset": "tsx src/cli/reset-errors.ts",
    "errors:list": "tsx src/cli/reset-errors.ts --dry-run",
    "sense:report": "tsx scripts/qa-sense-report.ts --days=7",
    "sense:report:full": "tsx scripts/qa-sense-report.ts --days=30 --suggest-kb"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@types/express": "^5.0.6",
    "commander": "^12.1.0",
    "concurrently": "^9.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "playwright": "^1.44.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Models
DEFAULT_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5-20251001
POWERFUL_MODEL=claude-opus-4-7

# Redis (short-term memory)
REDIS_URL=redis://localhost:6379

# PostgreSQL + pgvector (long-term memory)
# Matches docker-compose.yml defaults
DATABASE_URL=postgresql://ailab:ailab@localhost:5433/ai_lab

# Observability
LOG_LEVEL=info

# Optional: Tavily for web search
TAVILY_API_KEY=tvly-...

# OpenAI (embeddings for vault semantic search)
OPENAI_API_KEY=sk-...

# Obsidian vault path
VAULT_PATH=~/obsidian-vault

# Resend — outbound email delivery
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=samir.ricardo@vrashows.com.br
RESEND_FROM_NAME=Samir Ricardo | VRASHOWS

# Outbound BCC — receives a copy of every outgoing email for audit and campaign monitoring
OUTBOUND_BCC_EMAIL=samir.ricardo@vrashows.com.br

# Media kit PDF — mandatory attachment for all outbound and follow-up emails
MEDIA_KIT_PDF=C:\Users\Administrador\Downloads\vrashows_media_kit_optimized.pdf

# Outbound scheduling and safe delivery limits
MAX_SENDS_PER_DAY=5
MAX_BATCH_SIZE=5
NO_SEND_AFTER=16:00
WEEKEND_BLOCK=true
OUTBOUND_RATE_DELAY_MS=120000

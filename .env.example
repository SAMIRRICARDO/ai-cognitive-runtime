# ── Anthropic (obrigatório) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key

# ── OpenAI (opcional — fallback) ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key

# ── Tavily (obrigatório para find_new_leads) ──────────────────────────────────
TAVILY_API_KEY=your_tavily_key

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL=your@email.com
RESEND_FROM_NAME=Seu Nome ou Empresa

# ── Outbound ──────────────────────────────────────────────────────────────────
# Caminho absoluto para o PDF anexado nos emails de outbound
MEDIA_KIT_PDF=/caminho/para/vrashows_media_kit.pdf
# BCC opcional em todos os emails enviados
OUTBOUND_BCC_EMAIL=

# ── Telegram (obrigatório para notificações do VRAXIA Sense) ─────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# ID do chat que receberá as notificações (obter via @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_SENDER_PROFILE=https://www.linkedin.com/in/your-profile/

# ── Infraestrutura — Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Infraestrutura — PostgreSQL + pgvector ────────────────────────────────────
# ATENÇÃO: Docker Compose expõe Postgres na porta 5433 (não 5432)
DATABASE_URL=postgresql://ailab:ailab@localhost:5433/ai_lab

# ── SaaS / Multi-tenant (obrigatório em produção, dispensável com DEV_MODE) ──
# Mínimo 32 caracteres
VRAXIA_MASTER_KEY=your_master_key_minimum_32_chars_here
VRAXIA_ADMIN_KEY=your_admin_key

# ── Portas ────────────────────────────────────────────────────────────────────
API_PORT=3000
WEBHOOK_PORT=3001

# ── Runtime ───────────────────────────────────────────────────────────────────
# DEV_MODE=true  → bypass tenant auth, injeta tenant "dev" sintético
# DEV_MODE=false → exige X-Api-Key header em todas as rotas protegidas
DEV_MODE=true

# ENABLE_MEMORY=false → desabilita Redis e Postgres sem crash (útil sem Docker)
# ENABLE_MEMORY=true  → ativa cache Redis e memória semântica pgvector
ENABLE_MEMORY=false

# CHEAP_MODE=true → força Haiku em todos os agentes, cap 512 tokens, 3 iterações
CHEAP_MODE=true
MAX_OUTPUT_TOKENS=512
